# Database provider and connection string.
# Use postgresql for production or hosted database providers (Neon, Supabase, Railway, etc.)
DATABASE_PROVIDER="postgresql"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# VERCEL DEPLOYMENT NOTES:
# 1. Set both DATABASE_URL and DATABASE_PROVIDER in Vercel → Settings → Environment Variables.
# 2. Select "Production, Preview, and Development" so they're available during build AND runtime.
# 3. After adding/changing env vars, trigger a fresh redeploy (don't just redeploy — clear cache).
# 4. If using Neon: use the "Pooled connection" string (ends in ?pgbouncer=true&sslmode=require).
#    The app automatically appends connection_limit=1 for Vercel serverless compatibility.
# 5. If using Supabase: use the "Transaction mode" pooler URL on port 6543.

# For local file-based development, switch to sqlite:
# DATABASE_PROVIDER="sqlite"
# DATABASE_URL="file:./dev.db"

# Hugging Face token (free tier, https://huggingface.co/settings/tokens)
HF_TOKEN=""
HF_MODEL="meta-llama/Llama-3.3-70B-Instruct"

# Ed25519 issuer signing key (any 64-char hex). Generate locally; do not check in.
FORGE_ISSUER_PRIVATE_KEY=""
NEXT_PUBLIC_FORGE_ISSUER_DID="did:web:forge.redrob.ai"

# Optional Anthropic key (we use HF/Llama for all real calls)
ANTHROPIC_API_KEY=""
